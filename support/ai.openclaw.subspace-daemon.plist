<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.subspace-daemon</string>
    <key>ProgramArguments</key>
    <array>
      <string>/Users/mike/.local/bin/subspace-daemon</string>
      <string>serve</string>
      <string>--config</string>
      <string>/Users/mike/.openclaw/subspace-daemon/config.json</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>/Users/mike</string>
    <key>StandardOutPath</key>
    <string>/Users/mike/.openclaw/subspace-daemon/logs/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mike/.openclaw/subspace-daemon/logs/stderr.log</string>
  </dict>
</plist>
